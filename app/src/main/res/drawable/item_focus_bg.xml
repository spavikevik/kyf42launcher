<?xml version="1.0" encoding="utf-8"?>
<!-- KaiOS-style selection: on a no-touch device the FOCUSED state is the cursor.
     Blue ring + faint blue fill marks the selected app. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="@color/kai_blue_fill" />
            <stroke android:width="2dp" android:color="@color/kai_blue" />
            <corners android:radius="8dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="8dp" />
        </shape>
    </item>
</selector>
