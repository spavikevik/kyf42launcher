<?xml version="1.0" encoding="utf-8"?>
<!-- Selection cursor: iOS-soft rounded card + KaiOS blue ring.
     On a no-touch device the FOCUSED state IS the cursor — keep it unmissable. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape android:shape="rectangle">
            <solid android:color="#2E00A9E0" />
            <stroke android:width="2dp" android:color="@color/kai_blue" />
            <corners android:radius="14dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@android:color/transparent" />
            <corners android:radius="14dp" />
        </shape>
    </item>
</selector>
