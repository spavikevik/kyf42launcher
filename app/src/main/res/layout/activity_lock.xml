<?xml version="1.0" encoding="utf-8"?>
<!-- Lock screen: same visual language as home — wallpaper, top status fade,
     big thin clock. Center key dismisses. -->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLock"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/wallpaper">

    <!-- top fade for status legibility -->
    <View
        android:id="@+id/lockTopFade"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="top"
        android:background="@drawable/topbar_fade" />

    <LinearLayout
        android:id="@+id/lockStatusRow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingTop="3dp">

        <ImageView
            android:id="@+id/lockWifi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginEnd="5dp"
            android:visibility="gone"
            android:contentDescription="@null" />

        <TextView
            android:id="@+id/lockCarrier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:singleLine="true"
            android:textColor="@color/text_secondary"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/lockBattery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@android:color/white"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- clock block, upper third like iOS -->
    <LinearLayout
        android:id="@+id/lockClockBlock"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="90dp"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextClock
            android:format12Hour="h:mm"
            android:format24Hour="H:mm"
            android:fontFamily="sans-serif-thin"
            android:letterSpacing="-0.01"
            android:textColor="@color/text_primary"
            android:shadowColor="#40000000"
            android:shadowDy="2"
            android:shadowRadius="8"
            android:textSize="76sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextClock
            android:format12Hour="EEEE, MMMM d"
            android:format24Hour="EEEE, MMMM d"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.08"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- unlock hint, bottom -->
    <TextView
        android:id="@+id/unlockHint"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="26dp"
        android:fontFamily="sans-serif-medium"
        android:letterSpacing="0.1"
        android:textAllCaps="true"
        android:textColor="@color/text_secondary"
        android:textSize="11sp"
        android:text="@string/unlock_hint" />
</FrameLayout>
